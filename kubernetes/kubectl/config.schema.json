{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/foomo/posh-providers/kubernetes/kubectl",
  "$ref": "#/$defs/Config",
  "$defs": {
    "ClusterConfig": {
      "properties": {
        "proxy": {
          "type": "string",
          "description": "Named SSH proxy from the top-level proxies map"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Config": {
      "properties": {
        "configPath": {
          "type": "string"
        },
        "clusters": {
          "additionalProperties": {
            "$ref": "#/$defs/ClusterConfig"
          },
          "type": "object"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}