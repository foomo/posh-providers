{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/foomo/posh-providers/azure/az",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Artifactory": {
      "properties": {
        "name": {
          "type": "string"
        },
        "resourceGroup": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Cluster": {
      "properties": {
        "name": {
          "type": "string",
          "description": "Cluster"
        },
        "resourceGroup": {
          "type": "string",
          "description": "Cluster resource group name"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Config": {
      "properties": {
        "configPath": {
          "type": "string",
          "description": "Config path"
        },
        "tenantId": {
          "type": "string",
          "description": "Tenant id"
        },
        "proxy": {
          "type": "string",
          "description": "Named SSH proxy for az login (tenant-level commands)"
        },
        "subscriptions": {
          "additionalProperties": {
            "$ref": "#/$defs/Subscription"
          },
          "type": "object",
          "description": "Subscription configurations"
        },
        "servicePrincipals": {
          "additionalProperties": {
            "$ref": "#/$defs/ServicePrincipal"
          },
          "type": "object",
          "description": "Authentication service principals"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "ServicePrincipal": {
      "properties": {
        "tenantId": {
          "type": "string",
          "description": "Tenant id"
        },
        "clientId": {
          "type": "string",
          "description": "Application client id"
        },
        "clientSecret": {
          "type": "string",
          "description": "Application password"
        }
      },
      "additionalProperties": false,
      "type": "object"
    },
    "Subscription": {
      "properties": {
        "name": {
          "type": "string"
        },
        "clusters": {
          "additionalProperties": {
            "$ref": "#/$defs/Cluster"
          },
          "type": "object"
        },
        "artifactories": {
          "additionalProperties": {
            "$ref": "#/$defs/Artifactory"
          },
          "type": "object"
        },
        "proxy": {
          "type": "string",
          "description": "Named SSH proxy for all commands in this subscription"
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}