{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/foomo/posh-providers/cli/cli",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Config": {
      "properties": {
        "scopes": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object",
          "description": "Required OAuth scopes per gh hostname."
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}