{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/foomo/posh-providers/sqlc-dev/sqlc",
  "$ref": "#/$defs/Config",
  "$defs": {
    "Config": {
      "properties": {
        "tempDir": {
          "type": "string"
        },
        "cacheDir": {
          "type": "string"
        },
        "findIgnore": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "description": "FindIgnore contains regular expressions for file and directory names to skip when discovering sqlc.yaml files."
        }
      },
      "additionalProperties": false,
      "type": "object"
    }
  }
}